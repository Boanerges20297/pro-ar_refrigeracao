SECRET_KEY=change-me-with-a-long-random-value
JWT_SECRET_KEY=change-me-with-another-long-random-value
DATABASE_URL=sqlite:///pronto_ar.db
UPLOAD_ROOT=uploads
MAX_CONTENT_LENGTH=8388608

# Recommended for Linux VPS behind Nginx with HTTPS
PREFERRED_URL_SCHEME=https
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_SSL_STRICT=false

# Reverse proxy / domain settings
PROXY_FIX_ENABLED=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=0
SERVER_NAME=
TRUSTED_HOSTS=

# SQLite concurrency tuning
SQLITE_BUSY_TIMEOUT_MS=30000
RATELIMIT_STORAGE_URI=memory://

# Licensing
# Legacy/dev fallback only. In producao, prefira LICENSE_PUBLIC_KEY_PATH.
LICENSE_SIGNING_SECRET=change-me-license-secret
LICENSE_PUBLIC_KEY_PATH=
LICENSE_WARNING_DAYS=15
LICENSE_GRACE_DAYS=7
LICENSE_INSTANCE_ID=
LICENSE_INSTALLATION_ID_PATH=instance/installation_id.txt
LICENSE_ALLOW_LEGACY_TOKENS=false